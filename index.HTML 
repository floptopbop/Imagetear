<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="GOBLIN_OS">
    <link rel="manifest" href="manifest.json">
    <title>GOBLIN_OS // PORTABLE_VAT</title>
    <style>
        :root { --neon: #39ff14; --void: #000; }
        * { box-sizing: border-box; }
        body { 
            background: var(--void); 
            color: var(--neon); 
            font-family: monospace; 
            margin: 0; 
            padding: 0;
            width: 100vw; 
            height: 100vh; 
            overflow: hidden;
        }
        #canvas-wrap { 
            width: 100%; 
            height: 100%; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            flex-direction: column;
            gap: 20px;
        }
        canvas { 
            max-width: 95vw; 
            max-height: 70vh; 
            box-shadow: 0 0 30px rgba(57, 255, 20, 0.3);
            border: 2px solid var(--neon);
            image-rendering: pixelated;
        }
        #controls {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            padding: 20px;
            width: 100%;
            background: rgba(0,0,0,0.5);
        }
        .btn, label { 
            background: var(--neon); 
            color: #000; 
            border: none; 
            padding: 12px 20px; 
            font-weight: bold; 
            border-radius: 3px; 
            text-align: center; 
            text-transform: uppercase; 
            font-size: 11px; 
            cursor: pointer;
            font-family: monospace;
            transition: all 0.1s;
            white-space: nowrap;
        }
        .btn:hover, label:hover { 
            background: #fff;
            text-shadow: 0 0 10px rgba(0,0,0,0.5);
        }
        .btn:active {
            transform: scale(0.95);
        }
        input[type="file"] { 
            display: none; 
        }
        input[type="range"] {
            width: 150px;
            height: 8px;
            cursor: pointer;
        }
        #status { 
            position: absolute; 
            top: 15px; 
            left: 15px; 
            font-size: 11px; 
            opacity: 0.8;
            line-height: 1.4;
            z-index: 10;
        }
        #info {
            position: absolute;
            bottom: 15px;
            right: 15px;
            font-size: 10px;
            opacity: 0.6;
            text-align: right;
            line-height: 1.3;
        }
        .label {
            font-size: 10px;
            opacity: 0.8;
        }
    </style>
</head>
<body>

<div id="status">
    ENGINE: VORT_PORTABLE_V4<br>
    STATUS: READY_FOR_TRAUMA<br>
    CHAOS: <span id="chaos-val">1.0</span><br>
    GYRO: <span id="g-val">OFF</span>
</div>

<div id="canvas-wrap">
    <canvas id="vort"></canvas>
    <div id="controls">
        <label for="loader" class="btn">📁 LOAD IMAGE</label>
        <input type="file" id="loader" accept="image/*">
        <span class="label" style="opacity: 0.6;">or paste URL:</span>
        <input type="text" id="url-input" placeholder="https://..." style="width: 200px; padding: 8px; background: #000; color: #39ff14; border: 1px solid #39ff14; font-family: monospace; font-size: 10px;">
        <button id="load-url-btn" class="btn">🌐 LOAD</button>
        <button id="perm-btn" class="btn">🎯 REQUEST GYRO (or move mouse)</button>
        <div>
            <span class="label">CHAOS:</span>
            <input type="range" id="chaos" min="0.1" max="3.0" step="0.1" value="1.0">
        </div>
        <button id="reset-btn" class="btn">🔄 RESET</button>
        <button id="inject-btn" class="btn">⚡ INJECT</button>
    </div>
</div>

<div id="info">
    Starts with test pattern. Load image or use defaults.<br>
    Blocks bounce off edges. Tilt or move finger to distort.
</div>

<script>
    const canvas = document.getElementById('vort');
    const ctx = canvas.getContext('2d', { willReadFrequently: true });
    const loader = document.getElementById('loader');
    const urlInput = document.getElementById('url-input');
    const loadUrlBtn = document.getElementById('load-url-btn');
    const permBtn = document.getElementById('perm-btn');
    const chaosSlider = document.getElementById('chaos');
    const resetBtn = document.getElementById('reset-btn');
    const injectBtn = document.getElementById('inject-btn');

    let state = {
        img: null,
        blocks: [],
        chaos: 1.0,
        gyro: { x: 0, y: 0 },
        active: false,
        gyroActive: false,
        frameCount: 0
    };

    // Generate procedural test pattern on startup
    function generateTestPattern() {
        canvas.width = window.innerWidth * 0.95;
        canvas.height = window.innerHeight * 0.6;
        
        const imgData = ctx.createImageData(canvas.width, canvas.height);
        const data = imgData.data;
        
        // Generate glitchy noise pattern
        for (let i = 0; i < data.length; i += 4) {
            const val = Math.sin(i * 0.0001) * 127 + 128;
            data[i] = val * Math.random();       // R
            data[i + 1] = val * Math.random();   // G
            data[i + 2] = val * Math.random();   // B
            data[i + 3] = 255;                   // A
        }
        
        ctx.putImageData(imgData, 0, 0);
        state.img = { width: canvas.width, height: canvas.height };
        buildQuadtree(imgData);
        state.active = true;
    }

    function buildQuadtree(imgData) {
        state.blocks = [];
        
        function split(x, y, w, h, depth) {
            if (w < 10 || h < 10 || (depth > 2 && Math.random() > 0.75)) {
                const i = (Math.floor(y + h/2) * canvas.width + Math.floor(x + w/2)) * 4;
                state.blocks.push({
                    x, y, w, h,
                    ox: x, oy: y,
                    vx: (Math.random() - 0.5) * 2,
                    vy: (Math.random() - 0.5) * 2,
                    color: `rgb(${imgData.data[i]},${imgData.data[i+1]},${imgData.data[i+2]})`,
                });
                return;
            }
            let hw = w/2, hh = h/2;
            split(x, y, hw, hh, depth + 1);
            split(x + hw, y, hw, hh, depth + 1);
            split(x, y + hh, hw, hh, depth + 1);
            split(x + hw, y + hh, hw, hh, depth + 1);
        }
        split(0, 0, canvas.width, canvas.height, 0);
    }

    // --- SENSOR ACTIVATION ---
    permBtn.onclick = async () => {
        console.log('Gyro button clicked');
        console.log('DeviceOrientationEvent:', typeof DeviceOrientationEvent);
        
        if (typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function') {
            console.log('Requesting permission (iOS)');
            try {
                const res = await DeviceOrientationEvent.requestPermission();
                console.log('Permission result:', res);
                if (res === 'granted') {
                    window.addEventListener('deviceorientation', handleDeviceOrientation);
                    permBtn.innerText = '✓ GYRO ACTIVE';
                    permBtn.style.opacity = '0.5';
                    permBtn.disabled = true;
                    document.getElementById('g-val').innerText = 'ACTIVE';
                }
            } catch (err) {
                console.log('Permission error:', err);
            }
        } else {
            console.log('No permission needed - using direct listener');
            window.addEventListener('deviceorientation', handleDeviceOrientation);
            permBtn.innerText = '✓ GYRO ACTIVE';
            permBtn.style.opacity = '0.5';
            permBtn.disabled = true;
            document.getElementById('g-val').innerText = 'ACTIVE';
        }
        if ("vibrate" in navigator) navigator.vibrate(50);
    };

    function handleDeviceOrientation(e) {
        state.gyro.x = (e.gamma || 0) * 5.0;
        state.gyro.y = (e.beta || 0) * 5.0;
        state.gyroActive = true;
    }

    // Fallback: track mouse/touch movement for gyro effect
    let lastX = window.innerWidth / 2;
    let lastY = window.innerHeight / 2;

    document.addEventListener('mousemove', (e) => {
        if (!state.gyroActive) {
            let dx = (e.clientX - lastX) * 0.1;
            let dy = (e.clientY - lastY) * 0.1;
            state.gyro.x = dx;
            state.gyro.y = dy;
        }
        lastX = e.clientX;
        lastY = e.clientY;
    });

    document.addEventListener('touchmove', (e) => {
        if (!state.gyroActive && e.touches.length > 0) {
            let dx = (e.touches[0].clientX - lastX) * 0.1;
            let dy = (e.touches[0].clientY - lastY) * 0.1;
            state.gyro.x = dx;
            state.gyro.y = dy;
        }
        lastX = e.touches[0]?.clientX || lastX;
        lastY = e.touches[0]?.clientY || lastY;
    }, { passive: true });

    // --- IMAGE CONSUMPTION (FILE) ---
    loader.onchange = (e) => {
        const reader = new FileReader();
        reader.onload = (event) => {
            const img = new Image();
            img.onload = () => {
                state.img = img;
                state.chaos = 1.0;
                chaosSlider.value = 1.0;
                processImage();
            };
            img.src = event.target.result;
        };
        reader.readAsDataURL(e.target.files[0]);
    };

    // --- IMAGE CONSUMPTION (URL) ---
    loadUrlBtn.onclick = () => {
        let url = urlInput.value.trim();
        if (!url) return;
        
        // Use CORS proxy for cross-origin images
        if (!url.includes('cors-anywhere') && !url.includes('localhost')) {
            url = 'https://cors-anywhere.herokuapp.com/' + url;
        }
        
        const img = new Image();
        img.crossOrigin = "anonymous";
        img.onload = () => {
            state.img = img;
            state.chaos = 1.0;
            chaosSlider.value = 1.0;
            processImage();
        };
        img.onerror = () => {
            alert('Failed to load image. Try another URL or use file upload.');
            console.log('Image load error for:', url);
        };
        img.src = url;
    };

    // --- DRAG AND DROP ---
    canvas.ondragover = (e) => {
        e.preventDefault();
        canvas.style.opacity = '0.5';
    };
    canvas.ondragleave = () => {
        canvas.style.opacity = '1';
    };
    canvas.ondrop = (e) => {
        e.preventDefault();
        canvas.style.opacity = '1';
        const files = e.dataTransfer.files;
        if (files.length > 0 && files[0].type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = (event) => {
                const img = new Image();
                img.onload = () => {
                    state.img = img;
                    state.chaos = 1.0;
                    chaosSlider.value = 1.0;
                    processImage();
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(files[0]);
        }
    };

    function processImage() {
        const screenW = window.innerWidth;
        const screenH = window.innerHeight * 0.7;
        let scale = Math.min(screenW / state.img.width, screenH / state.img.height) * 0.95;
        canvas.width = state.img.width * scale;
        canvas.height = state.img.height * scale;
        
        ctx.drawImage(state.img, 0, 0, canvas.width, canvas.height);
        const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        
        buildQuadtree(imgData);
        state.active = true;
    }

    // --- CHAOS CONTROL ---
    chaosSlider.oninput = (e) => {
        state.chaos = parseFloat(e.target.value);
        document.getElementById('chaos-val').innerText = state.chaos.toFixed(1);
    };

    resetBtn.onclick = () => {
        state.chaos = 1.0;
        chaosSlider.value = 1.0;
        document.getElementById('chaos-val').innerText = '1.0';
        if ("vibrate" in navigator) navigator.vibrate([20, 10, 20]);
    };

    injectBtn.onclick = () => {
        state.chaos = Math.min(state.chaos + 0.3, 3.0);
        chaosSlider.value = state.chaos;
        document.getElementById('chaos-val').innerText = state.chaos.toFixed(1);
        if ("vibrate" in navigator) navigator.vibrate(30);
    };

    // --- THE KINETIC LOOP ---
    function draw() {
        if (state.active) {
            // Smear with semi-transparency
            ctx.fillStyle = `rgba(0,0,0,${0.08 * state.chaos})`;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Saturation boost
            ctx.filter = `saturate(${100 + (state.chaos * 50)}%) contrast(${100 + (state.chaos * 20)}%)`;

            state.blocks.forEach(b => {
                // Apply velocity from bouncing
                b.vx += (Math.random() - 0.5) * state.chaos * 0.1;
                b.vy += (Math.random() - 0.5) * state.chaos * 0.1;
                
                // Cap velocity
                b.vx = Math.max(-3, Math.min(3, b.vx));
                b.vy = Math.max(-3, Math.min(3, b.vy));
                
                // Apply velocity
                b.x += b.vx * state.chaos;
                b.y += b.vy * state.chaos;

                // BOUNCING OFF EDGES
                if (b.x < 0) {
                    b.x = 0;
                    b.vx *= -0.8;
                }
                if (b.x + b.w > canvas.width) {
                    b.x = canvas.width - b.w;
                    b.vx *= -0.8;
                }
                if (b.y < 0) {
                    b.y = 0;
                    b.vy *= -0.8;
                }
                if (b.y + b.h > canvas.height) {
                    b.y = canvas.height - b.h;
                    b.vy *= -0.8;
                }
                
                // Gyro distortion
                let tx = state.gyro.x * 2.5 * state.chaos;
                let ty = state.gyro.y * 2.5 * state.chaos;
                
                // Chaos-driven jitter
                let dx = (Math.random() - 0.5) * state.chaos * 2.0;
                let dy = (Math.random() - 0.5) * state.chaos * 2.0;
                
                ctx.fillStyle = b.color;
                ctx.globalAlpha = 0.85 + Math.random() * 0.15;
                ctx.fillRect(
                    b.x + tx + dx, 
                    b.y + ty + dy, 
                    b.w - 0.5, 
                    b.h - 0.5
                );
            });
            
            ctx.globalAlpha = 1.0;
            ctx.filter = 'none';
        }
        state.frameCount++;
        requestAnimationFrame(draw);
    }

    // --- TOUCH INTERACTION ---
    canvas.ontouchstart = canvas.onmousedown = () => {
        state.chaos = Math.min(state.chaos + 0.05, 3.0);
        chaosSlider.value = state.chaos;
        document.getElementById('chaos-val').innerText = state.chaos.toFixed(1);
        if ("vibrate" in navigator && Math.random() > 0.8) navigator.vibrate(5);
    };

    // Handle window resize
    window.addEventListener('resize', () => {
        if (state.img) {
            processImage();
        }
    });

    // Start with test pattern
    generateTestPattern();
    draw();

    // Register service worker for offline support
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('sw.js').catch(() => {
            console.log('Service worker registration failed (offline ok)');
        });
    }


</script>

</body>
</html>